{
  "manifest_version": 3,
  "name": "Word Blocker for YouTube",
  "version": "1.0.0",
  "description": "Automatically hide or blur YouTube videos whose title or description contains words/terms you want to avoid.",
  "permissions": ["storage"],
  "host_permissions": ["*://*.youtube.com/*"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Word Blocker for YouTube"
  },
  "content_scripts": [
    {
      "matches": ["*://*.youtube.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
